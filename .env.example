OPENAI_API_KEY=
APP_MODE=free

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=
# Service-role key + JWT secret (Project Settings -> API in Supabase). Required
# for server-side quota enforcement and Stripe webhook writes; without them the
# app runs unlimited/free exactly like before.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

STRIPE_SECRET_KEY=
# Two Stripe Price ids for the Pro plan (create both in the Stripe dashboard):
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
# Signing secret from the Stripe webhook endpoint (dashboard -> Developers -> Webhooks)
STRIPE_WEBHOOK_SECRET=
